# Dentalia form service — copy to ".env" on the VPS and fill in.
# (systemd loads this via EnvironmentFile=, see dentalia-forms.service)

# --- where the service listens (nginx proxies /api/* here) ---
HOST=127.0.0.1
PORT=8787

# --- SMTP (ask the e-mail provider; e.g. Hostinger Mail / your mail host) ---
# Hostinger Mail example: host=smtp.hostinger.com  port=465  secure=true
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=praxis@dr-ehrlichmann.de
SMTP_PASS=__HIER_DAS_POSTFACH_PASSWORT__

# --- addresses ---
# From should match SMTP_USER's domain so SPF/DKIM pass (see DNS-EMAIL.md).
MAIL_FROM=Zahnarztpraxis Dr. Ehrlichmann <praxis@dr-ehrlichmann.de>
MAIL_TO=praxis@dr-ehrlichmann.de
AUTOREPLY=true

# --- misc ---
SITE_URL=https://dr-ehrlichmann.de
ALLOWED_ORIGIN=https://dr-ehrlichmann.de
DATA_DIR=/var/lib/dentalia-forms
RATE_MAX=6
RATE_WINDOW_MS=600000
