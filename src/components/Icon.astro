---
// Shared inline SVG icons (chrome + common UI). Section-specific icons stay inline
// in their page for 1:1 fidelity with the locked mockup.
interface Props {
  name: string;
  size?: number | string;
  class?: string;
  strokeWidth?: number;
}
const { name, size = '1em', class: cls = '', strokeWidth = 1.7 } = Astro.props;

const paths: Record<string, string> = {
  phone: '<path d="M6 3h3l2 5-2.5 1.5a12 12 0 0 0 6 6L16 13l5 2v3a2 2 0 0 1-2 2A16 16 0 0 1 4 5a2 2 0 0 1 2-2z"/>',
  calendar: '<rect x="3.5" y="5" width="17" height="15" rx="2"/><path d="M3.5 9h17M8 3.5v3M16 3.5v3"/>',
  pin: '<path d="M12 21s7-5.4 7-11a7 7 0 1 0-14 0c0 5.6 7 11 7 11z"/><circle cx="12" cy="10" r="2.5"/>',
  menu: '<path d="M4 7h16M4 12h16M4 17h16"/>',
  arrowUp: '<path d="M12 19V5M5 12l7-7 7 7"/>',
  chat: '<path d="M21 11.5a8.4 8.4 0 0 1-11.9 7.6L4 20l1-4.1A8.4 8.4 0 1 1 21 11.5z"/>',
  check: '<path d="M5 12l4 4 10-10"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  tooth: '<path d="M7 3.6C5.3 3.6 4 5 4 6.9c0 1 .2 1.9.5 3.2.2.9.3 1.9.5 3.1.4 2.4.7 4.6 1.5 5.7.6.8 1.4.5 1.7-.4.4-1.1.6-2.5.9-3.6.2-.8.5-1.4.9-1.4s.7.6.9 1.4c.3 1.1.5 2.5.9 3.6.3.9 1.1 1.2 1.7.4.8-1.1 1.1-3.3 1.5-5.7.2-1.2.3-2.2.5-3.1.3-1.3.5-2.2.5-3.2 0-1.9-1.3-3.3-3-3.3-1.1 0-2 .6-3 .6s-1.9-.6-3-.6z"/>',
};
const d = paths[name] ?? '';
const px = typeof size === 'number' ? `${size}px` : size;
---
<svg
  class={`ic ${cls}`.trim()}
  style={`width:${px};height:${px}`}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={d}
></svg>
